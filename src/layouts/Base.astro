---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root { color-scheme: light dark; }
      body {
        font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
        max-width: 960px;
        margin: 2rem auto;
        padding: 0 1rem;
        line-height: 1.55;
        color: #1a1a1a;
        background: #fafafa;
      }
      h1, h2, h3 { font-weight: 600; line-height: 1.25; }
      h1 { font-size: 1.75rem; margin-top: 0.25rem; }
      h2 { font-size: 1.25rem; margin-top: 2rem; }
      a { color: #1a4a7a; }
      header nav { font-size: 0.95rem; margin-bottom: 1.5rem; }
      header nav a { margin-right: 0.5rem; }
      table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
      th, td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #ddd; vertical-align: top; }
      th { background: #f0f0f0; font-weight: 600; }
      .muted { color: #555; font-size: 0.92rem; }
      .confidence-badge {
        display: inline-block;
        padding: 0.15rem 0.55rem;
        border-radius: 0.25rem;
        font-weight: 600;
        text-decoration: none;
      }
      .confidence-badge.low { background: #fddede; color: #8a1f1f; }
      .confidence-badge.mid { background: #fdecc8; color: #7a4a00; }
      .confidence-badge.high { background: #d8f0d4; color: #1f6a2f; }
      .evidence-card {
        border: 1px solid #ddd;
        border-radius: 0.3rem;
        padding: 0.75rem 1rem;
        margin: 0.6rem 0;
        background: #fff;
      }
      .evidence-type {
        display: inline-block;
        background: #eef;
        color: #224;
        padding: 0.05rem 0.45rem;
        border-radius: 0.2rem;
        font-size: 0.8rem;
        margin-right: 0.5rem;
      }
      footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #ddd; color: #555; font-size: 0.85rem; }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href="/">siteatlas</a>
        <a href="/methodology/">methodology</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>data fixture for the ercot slice; see <a href="/methodology/">methodology</a> and the voice charter in <code>decisions/</code>.</p>
    </footer>
  </body>
</html>
